APP_ENV=production
LOG_LEVEL=INFO

DATABASE_PATH=data/expertboat.db
KNOWLEDGE_DIR=knowledge

# External storage for manuals, raw exports, review FAQ and chunks.
# Windows default: D:\expertboat-data
# Linux/VPS default: /data/expertboat-data
EXPERTBOAT_DATA_DIR=

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_MANAGER_CHAT_ID=

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional DeepSeek provider settings:
# LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
AVITO_USER_ID=
AVITO_API_BASE_URL=https://api.avito.ru
AVITO_POLL_INTERVAL_SECONDS=5
